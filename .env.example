# AgentForge configuration — copy to .env and fill in.
# NEVER commit a real .env. See ARCHITECTURE.md "auth model" for the trust boundaries.

# ---- Target: the deployed Clinical Co-Pilot under test ----
AGENTFORGE_TARGET_BASE_URL=https://abundant-art-production-d560.up.railway.app
# How AgentForge authenticates to the target (see HANDOFF.md "target auth").
# Filled in once the recon pass confirms the auth model.
AGENTFORGE_TARGET_AUTH_MODE=session          # session | apikey | none
AGENTFORGE_TARGET_USERNAME=
AGENTFORGE_TARGET_PASSWORD=
AGENTFORGE_TARGET_API_KEY=

# ---- LLMs (OPTIONAL) ----
# Both agents run on deterministic cores by default. Setting *_BASE_URL turns the
# corresponding LLM ON; leaving it EMPTY keeps the deterministic path. Any
# OpenAI-compatible /chat/completions endpoint works. The dashboard shows which
# ones are active. Set these where the service has egress to the endpoint.
#
# Examples (uncomment ONE block per role):
#   OpenAI:     BASE_URL=https://api.openai.com/v1        MODEL=gpt-4o-mini     API_KEY=sk-...
#   OpenRouter: BASE_URL=https://openrouter.ai/api/v1     MODEL=qwen/qwen-2.5-72b-instruct   API_KEY=sk-or-...
#   LM Studio:  BASE_URL=http://localhost:1234/v1         MODEL=<loaded model>  API_KEY=lm-studio   (local, free, no refusals)
#   Ollama:     BASE_URL=http://localhost:11434/v1        MODEL=llama3.1:8b     API_KEY=ollama      (local, free, no refusals)

# Red Team model — generates attack variants; must NOT refuse offensive prompts
# (prefer a local/open or uncensored model). Empty => deterministic mutations.
REDTEAM_BASE_URL=
REDTEAM_MODEL=llama3.1:8b
REDTEAM_API_KEY=

# Judge model — INDEPENDENT of the Red Team by design (use a different provider/
# model). Empty => deterministic rubric. A frontier model is recommended here.
JUDGE_BASE_URL=
JUDGE_MODEL=gpt-4o-mini
JUDGE_API_KEY=

# ---- History store (OPTIONAL) ----
# Cross-run campaign history powers the dashboard's "Trends over time" card.
# Leave DATABASE_URL unset and it uses a local SQLite file (runs/history.db) —
# fine for local dev, but a PaaS filesystem is ephemeral so that history is lost
# on redeploy. Set DATABASE_URL to a Postgres instance for durable history.
# On Railway: add the Postgres plugin and it injects DATABASE_URL automatically.
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=
# Override the local SQLite path (only used when DATABASE_URL is empty):
# AGENTFORGE_HISTORY_DB=runs/history.db

# ---- Budget guardrails (Orchestrator enforces these) ----
AGENTFORGE_MAX_USD_PER_RUN=2.00
AGENTFORGE_MAX_ATTEMPTS_PER_CAMPAIGN=50
AGENTFORGE_MAX_TURNS=6
